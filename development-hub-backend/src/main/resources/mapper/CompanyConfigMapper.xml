<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="xin.rexy.developmenthubbackend.mapper.CompanyConfigMapper">

    <select id="selectByConfigKey" resultType="xin.rexy.developmenthubbackend.model.entity.CompanyConfigEntity">
        SELECT id, config_key, config_value, updated_by, updated_at
        FROM company_config
        WHERE config_key = #{configKey}
        LIMIT 1
    </select>

</mapper>
